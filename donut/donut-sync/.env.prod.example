# donut-sync self-hosted (token mode) — production env.
# Copy to `.env` in the assembled deploy dir and fill in REAL secrets.
# Generate strong values:  openssl rand -hex 32

# Shared secret the client sends as `Authorization: Bearer <SYNC_TOKEN>`.
# This is the ONLY credential — anyone with it reads/writes the whole bucket.
SYNC_TOKEN=CHANGE_ME_openssl_rand_hex_32

PORT=12342

# MUST be the PUBLIC endpoint the client can reach — the sync server both
# presigns URLs with it AND makes direct S3 calls to it (host networking makes
# the server hairpin to its own public IP). Never localhost here.
S3_ENDPOINT=http://YOUR_SERVER_IP:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=CHANGE_ME_minio_user
S3_SECRET_ACCESS_KEY=CHANGE_ME_minio_password_min_8_chars
S3_BUCKET=donut-sync
S3_FORCE_PATH_STYLE=true

# MinIO root creds — keep identical to S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY.
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min_8_chars
